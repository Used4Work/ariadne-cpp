prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: ariadne
Description: C++17 LLM workflow orchestration library
Version: @PROJECT_VERSION@
URL: https://github.com/Used4Work/ariadne-cpp

Requires:
Libs: -L${libdir} -lariadne
Libs.private: -lcurl -lpthread
Cflags: -I${includedir} -std=c++17
